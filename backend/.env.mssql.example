# Standalone MSSQL simulation for packaged backend testing.
# docker-compose.mssql.yml reads this example by default. Copy it to
# .env.mssql only when you need local overrides that should stay ignored by Git.
#
# The packaged backend runs as a host process, so its own .env should use:
# DB_HOST=127.0.0.1
# DB_PORT=1433
# DB_USER=sa
# DB_PASSWORD=<same as MSSQL_SA_PASSWORD>
#
# Site target remains Microsoft SQL Server 2016. This container uses SQL Server
# 2022 only as a local/sandbox substitute and does not prove SQL Server 2016
# compatibility by itself.

MSSQL_SA_PASSWORD=AIIS_PMMS_Dev_789!
