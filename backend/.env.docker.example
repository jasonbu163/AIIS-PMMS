APP_ENV=development
APP_NAME=AIIS-PMMS Backend
API_PREFIX=/api/v1
TZ=Asia/Shanghai

# Docker Compose dev runtime:
# - api container connects to mssql-dev by service name.
# - host browser accesses backend through http://127.0.0.1:18080.
DATABASE_URL=
DB_DIALECT=mssql
DB_HOST=mssql-dev
DB_PORT=1433
DB_NAME=AIIS_PMMS
DB_USER=sa
DB_PASSWORD=AIIS_PMMS_Dev_789!
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=true

# SQL Server container requires this variable name.
MSSQL_SA_PASSWORD=AIIS_PMMS_Dev_789!

SQLITE_DATABASE=./pmms-dev.db

JWT_SECRET_KEY=change-me-in-docker-dev-env
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

BOOTSTRAP_ROOT_USERNAME=root
BOOTSTRAP_ROOT_PASSWORD=change-me-in-real-docker-env

# Docker dev can enable this when testing protected maintenance APIs.
ENABLE_MAINTENANCE_API=true
MAINTENANCE_TOKEN=change-me-docker-maintenance-token
