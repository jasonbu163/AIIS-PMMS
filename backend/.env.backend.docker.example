APP_ENV=development
APP_NAME=AIIS-PMMS Backend
API_PREFIX=/api/v1
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
TZ=Asia/Shanghai

# Backend-only container runtime:
# - Use host.docker.internal on Docker Desktop when SQL Server runs on the host
#   or when standalone docker-compose.mssql.yml publishes SQL Server on the host.
# - Use the real LAN IP/DNS when connecting to a site SQL Server.
# - Do not use localhost here unless SQL Server runs inside the same container.
DATABASE_URL=
DB_DIALECT=mssql
DB_HOST=host.docker.internal
DB_PORT=1433
DB_NAME=AIIS_PMMS
DB_USER=sa
DB_PASSWORD=AIIS_PMMS_Dev_789!
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=true

SQLITE_DATABASE=./pmms-dev.db

JWT_SECRET_KEY=dev-only-aiis-pmms-change-before-site
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

BOOTSTRAP_ROOT_USERNAME=root
BOOTSTRAP_ROOT_PASSWORD="#789@root"

# Enable for local packaged/container simulation; disable for real production
# unless a controlled site initialization or upgrade needs it.
ENABLE_MAINTENANCE_API=true
MAINTENANCE_TOKEN=aiis-pmms-dev-maintenance-token
