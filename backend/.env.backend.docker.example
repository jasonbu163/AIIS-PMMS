APP_ENV=development
APP_NAME=AIIS-PMMS Backend
API_PREFIX=/api/v1
TZ=Asia/Shanghai

# Backend-only container runtime:
# - Use host.docker.internal on Docker Desktop when SQL Server runs on the host.
# - Use the real LAN IP/DNS when connecting to a site SQL Server.
DATABASE_URL=
DB_DIALECT=mssql
DB_HOST=host.docker.internal
DB_PORT=1433
DB_NAME=AIIS_PMMS
DB_USER=sa
DB_PASSWORD=change-me
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=true

SQLITE_DATABASE=./pmms-dev.db

JWT_SECRET_KEY=change-me-in-backend-docker-env
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

BOOTSTRAP_ROOT_USERNAME=root
BOOTSTRAP_ROOT_PASSWORD=change-me-in-real-env

# Protected database maintenance API. Keep disabled unless the site needs it.
ENABLE_MAINTENANCE_API=false
MAINTENANCE_TOKEN=change-me-maintenance-token
