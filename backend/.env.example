APP_ENV=development
APP_NAME=AIIS-PMMS Backend
API_PREFIX=/api/v1
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
TZ=Asia/Shanghai

# Comma-separated browser origins allowed to call this API.
# Keep empty when the backend is served from the same origin as the frontend.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Host-local source runtime or packaged backend runtime:
# - Backend runs on the host through uv or from dist/aiis-pmms-backend.
# - For standalone MSSQL simulation, start docker-compose.mssql.yml and use
#   DB_HOST=127.0.0.1 with the host-published DB_PORT.
# - When the real site SQL Server is ready, change DB_HOST/DB_PORT/DB_USER/
#   DB_PASSWORD to the site database values.
#
# Production/site database target: Microsoft SQL Server 2016.
# Standalone simulation container: SQL Server 2022 for local testing only.
# DATABASE_URL has priority when provided. Leave it empty for normal structured
# DB_* settings; do not put a bare IP address in DATABASE_URL.
DATABASE_URL=
DB_DIALECT=mssql
DB_HOST=127.0.0.1
DB_PORT=1433
DB_NAME=AIIS_PMMS
DB_USER=sa
DB_PASSWORD=change-me
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=true

# Local test/development fallback only.
SQLITE_DATABASE=./pmms-dev.db

JWT_SECRET_KEY=change-me-in-site-env
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

# Real .env is not committed to GitHub and may contain the site plaintext.
# .env.example keeps placeholders only.
BOOTSTRAP_ROOT_USERNAME=root
BOOTSTRAP_ROOT_PASSWORD=change-me-in-real-env

# Protected database maintenance API. Keep disabled unless the site needs it.
ENABLE_MAINTENANCE_API=false
MAINTENANCE_TOKEN=change-me-maintenance-token
