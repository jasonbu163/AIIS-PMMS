APP_ENV=development
APP_NAME=AIIS-PMMS Backend
API_PREFIX=/api/v1
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
TZ=Asia/Shanghai

# Production/site database target: Microsoft SQL Server 2016.
# DATABASE_URL has priority when provided.
DATABASE_URL=
DB_DIALECT=mssql
DB_HOST=127.0.0.1
DB_PORT=1433
DB_NAME=AIIS_PMMS
DB_USER=sa
DB_PASSWORD=change-me
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=true

# Local test/development fallback only.
SQLITE_DATABASE=./pmms-dev.db

JWT_SECRET_KEY=change-me-in-site-env
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

# Real .env is not committed to GitHub and may contain the site plaintext.
# .env.example keeps placeholders only.
BOOTSTRAP_ROOT_USERNAME=root
BOOTSTRAP_ROOT_PASSWORD=change-me-in-real-env

# Protected database maintenance API. Keep disabled unless the site needs it.
ENABLE_MAINTENANCE_API=false
MAINTENANCE_TOKEN=change-me-maintenance-token
